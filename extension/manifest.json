{
  "manifest_version": 3,
  "name": "CampusShield AI",
  "version": "1.0",
  "description": "Real-Time Student Digital Safety Infrastructure",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "*://*/*"
  ],
  "background": {
    "scripts": [
      "config.js",
      "background.js"
    ],
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}